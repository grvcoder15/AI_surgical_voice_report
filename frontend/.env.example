# Frontend API base URL
# - Keep empty when frontend and backend are served from same domain via reverse proxy.
# - Set full URL when backend is on a different domain.
REACT_APP_API_URL=

# API request timeout in milliseconds (default: 30000)
REACT_APP_API_TIMEOUT_MS=30000

# localStorage key for storing authentication token (default: surgical_token)
REACT_APP_TOKEN_STORAGE_KEY=surgical_token
