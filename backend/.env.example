PORT=3001
WEBHOOK_MAX_PAYLOAD=10mb
SAVE_REPORTS_TO_DISK=false

# Perplexity Configuration
PERPLEXITY_API_KEY=your_perplexity_api_key_here
PERPLEXITY_MODEL=sonar-pro
PERPLEXITY_API_URL=https://api.perplexity.ai/chat/completions

# SMTP Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=info@handnervemicrosurgery.com
SMTP_PASS=your_app_password_here
EMAIL_FROM=info@handnervemicrosurgery.com
EMAIL_TO=recipient1@example.com,recipient2@example.com

# Webhook Security (optional)
WEBHOOK_SECRET=your_webhook_secret_here

# PostgreSQL
DATABASE_URL=postgresql://surgical_app:your_db_password@localhost:5432/ai_surgical_voice_report

# Auth
AUTH_TOKEN_SECRET=replace_with_a_long_random_secret
AUTH_TOKEN_TTL=7d
PASSWORD_SALT_ROUNDS=10
PASSWORD_RESET_TTL_MINUTES=15

# Frontend
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Retell
RETELL_BASE_URL=https://api.retellai.com
RETELL_TIMEOUT_MS=30000
